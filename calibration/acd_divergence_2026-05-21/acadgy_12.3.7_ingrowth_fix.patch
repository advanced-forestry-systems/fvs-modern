+  # ---- #127 ingrowth carry-through fix --------------------------------------
+  # ING.TreeList recruits lack the calibration-multiplier and size-cap columns,
+  # so without this they never grow (dDBH * NA -> coalesced to 0). Give recruits
+  # neutral multipliers and species size caps inherited from the survivors.
+  if (!is.null(ingrow) && nrow(ingrow) > 0) {
+    .cap <- unique(tree[, c("SP","max.dbh","max.height")])
+    .cap <- .cap[!duplicated(.cap$SP), ]
+    .mi  <- match(ingrow$SP, .cap$SP)
+    ingrow$dDBH.mult  <- 1
+    ingrow$dHt.mult   <- 1
+    ingrow$mort.mult  <- 1
+    ingrow$max.dbh    <- ifelse(is.na(.cap$max.dbh[.mi]),    200, .cap$max.dbh[.mi])
+    ingrow$max.height <- ifelse(is.na(.cap$max.height[.mi]),  60, .cap$max.height[.mi])
+  }
   tree = dplyr::bind_rows(tree, ingrow)
  
  
